# app/providers/twelvedata.py

from __future__ import annotations

import os
from typing import Any, Optional, List

import requests
from pydantic import BaseModel, Field


class ProviderError(RuntimeError):
    pass


class QuoteModel(BaseModel):
    symbol: Optional[str] = None
    name: Optional[str] = None
    exchange: Optional[str] = None
    currency: Optional[str] = None

    price: Optional[float] = None
    open: Optional[float] = None
    high: Optional[float] = None
    low: Optional[float] = None
    previous_close: Optional[float] = Field(default=None, alias="previous_close")

    change: Optional[float] = None
    percent_change: Optional[float] = None

    timestamp: Optional[str] = None  # provider timestamp string


class BarModel(BaseModel):
    ts_event: Optional[str] = None  # datetime string from provider
    open: Optional[float] = None
    high: Optional[float] = None
    low: Optional[float] = None
    close: Optional[float] = None
    volume: Optional[float] = None


class QuoteResult(BaseModel):
    provider: str = "twelvedata"
    quote: QuoteModel


class BarsResult(BaseModel):
    provider: str = "twelvedata"
    bars: List[BarModel]


def _to_float(v: Any) -> Optional[float]:
    if v is None:
        return None
    if isinstance(v, (int, float)):
        return float(v)
    s = str(v).strip()
    if not s:
        return None
    try:
        return float(s)
    except Exception:
        return None


class TwelveDataClient:
    """
    Minimal TwelveData client for:
      - quote
      - time_series (bars)
      - symbol_search
    Uses TWELVEDATA_API_KEY from environment.
    """

    BASE_URL = "https://api.twelvedata.com"

    def __init__(self, api_key: Optional[str] = None, timeout_s: int = 12):
        self.api_key = (api_key or os.getenv("TWELVEDATA_API_KEY", "")).strip()
        if not self.api_key:
            raise ProviderError("TWELVEDATA_API_KEY is required")
        self.timeout_s = timeout_s

    def _get(self, path: str, params: dict[str, Any]) -> dict[str, Any]:
        url = f"{self.BASE_URL}{path}"
        params = dict(params)
        params["apikey"] = self.api_key

        try:
            r = requests.get(url, params=params, timeout=self.timeout_s)
        except Exception as e:
            raise ProviderError(f"TwelveData request failed: {e}") from e

        # TwelveData often returns 200 with {"status":"error", ...}
        try:
            data = r.json()
        except Exception:
            raise ProviderError(f"TwelveData returned non-JSON response (status {r.status_code})")

        if isinstance(data, dict) and data.get("status") == "error":
            msg = data.get("message") or "TwelveData error"
            raise ProviderError(msg)

        if r.status_code >= 400:
            raise ProviderError(f"TwelveData HTTP {r.status_code}")

        if not isinstance(data, dict):
            raise ProviderError("TwelveData unexpected response format")

        return data

    def search_symbols(self, query: str, limit: int = 20) -> list[dict[str, Any]]:
        data = self._get("/symbol_search", {"symbol": query, "outputsize": limit})
        # Typical response: {"data":[...], "status":"ok"} or {"data":...}
        results = data.get("data")
        if isinstance(results, list):
            return results
        return []

    def fetch_quote(self, symbol: str) -> QuoteResult:
        sym = symbol.strip().upper()
        data = self._get("/quote", {"symbol": sym})

        q = QuoteModel(
            symbol=data.get("symbol") or sym,
            name=data.get("name"),
            exchange=data.get("exchange"),
            currency=data.get("currency"),
            price=_to_float(data.get("close") or data.get("price")),
            open=_to_float(data.get("open")),
            high=_to_float(data.get("high")),
            low=_to_float(data.get("low")),
            previous_close=_to_float(data.get("previous_close")),
            change=_to_float(data.get("change")),
            percent_change=_to_float(data.get("percent_change")),
            timestamp=str(data.get("timestamp")) if data.get("timestamp") is not None else None,
        )
        return QuoteResult(provider="twelvedata", quote=q)

    def fetch_bars(self, symbol: str, interval: str = "1day", outputsize: int = 500) -> BarsResult:
        sym = symbol.strip().upper()

        data = self._get(
            "/time_series",
            {
                "symbol": sym,
                "interval": interval,
                "outputsize": int(outputsize),
                "format": "JSON",
            },
        )

        values = data.get("values")
        if not isinstance(values, list):
            # Some responses may return single dict
            values = []

        bars: list[BarModel] = []
        for row in values:
            if not isinstance(row, dict):
                continue
            bars.append(
                BarModel(
                    ts_event=row.get("datetime"),
                    open=_to_float(row.get("open")),
                    high=_to_float(row.get("high")),
                    low=_to_float(row.get("low")),
                    close=_to_float(row.get("close")),
                    volume=_to_float(row.get("volume")),
                )
            )

        # TwelveData gives newest-first. Your code sorts later anyway, but keep it consistent.
        return BarsResult(provider="twelvedata", bars=bars)